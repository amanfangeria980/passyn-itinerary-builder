# --- Database (Neon or Supabase Postgres) ---
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# --- Auth ---
# 32+ random bytes, base64 or hex. Generate: `openssl rand -base64 48`
AUTH_SECRET=replace-with-32-plus-byte-secret

# --- LLM (Phase 2+) ---
NVIDIA_API_KEY=nvapi-xxx

# --- Stock images (Phase 3+) ---
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=passyn-itineraries
# Public base URL for serving R2 objects (custom domain or r2.dev)
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# --- App ---
NODE_ENV=development
